<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.db2work.ExportEmployeeToExcel">
  <grid id="27dc6" binding="ExportEmployeeToExcel" layout-manager="GridLayoutManager" row-count="4" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="5" left="5" bottom="5" right="5"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="e8780" binding="ExportFilePanel" layout-manager="GridLayoutManager" row-count="3" column-count="4" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="2" vsize-policy="1" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none" title="导出文件信息"/>
        <children>
          <component id="a75d3" class="javax.swing.JLabel" binding="FilePathLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="文件路径："/>
            </properties>
          </component>
          <component id="2a6" class="javax.swing.JLabel" binding="FilenameLabel">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="文件名："/>
            </properties>
          </component>
          <component id="b9c20" class="javax.swing.JTextField" binding="FilePath">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="2" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
            </constraints>
            <properties/>
          </component>
          <component id="ebe09" class="javax.swing.JButton" binding="BrowseButton">
            <constraints>
              <grid row="0" column="3" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="浏览..."/>
            </properties>
          </component>
          <component id="2d43a" class="javax.swing.JTextField" binding="FileName">
            <constraints>
              <grid row="1" column="1" row-span="1" col-span="3" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
            </constraints>
            <properties>
              <text value="ExportEmployee.xlsx"/>
            </properties>
          </component>
          <component id="8689a" class="javax.swing.JButton" binding="UseDateButton">
            <constraints>
              <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <icon value="calendar.png"/>
              <text value="使用当前日期"/>
            </properties>
          </component>
          <component id="f835d" class="javax.swing.JButton" binding="UseTimeButton">
            <constraints>
              <grid row="2" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <icon value="clock.png"/>
              <text value="使用当前时间"/>
            </properties>
          </component>
        </children>
      </grid>
      <component id="8c581" class="javax.swing.JButton" binding="OKButton">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <icon value="exportToExcel.png"/>
          <text value="导出全部"/>
        </properties>
      </component>
      <component id="6b304" class="javax.swing.JButton" binding="CancelButton">
        <constraints>
          <grid row="3" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <icon value="exit.png"/>
          <text value="退出向导"/>
        </properties>
      </component>
      <component id="a7973" class="javax.swing.JButton" binding="ExportSelectedButton">
        <constraints>
          <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <icon value="exportSelected.png"/>
          <text value="导出选中行"/>
        </properties>
      </component>
      <grid id="e49d2" binding="Preview" layout-manager="GridLayoutManager" row-count="4" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="2" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <scrollpane id="804c3" binding="PreviewPanel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="3" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
            <border type="none" title="导出信息预览"/>
            <children>
              <component id="e0c77" class="javax.swing.JTable" binding="PreviewTable">
                <constraints/>
                <properties>
                  <autoCreateRowSorter value="true"/>
                  <autoResizeMode value="0"/>
                  <enabled value="true"/>
                  <font size="12"/>
                </properties>
              </component>
            </children>
          </scrollpane>
          <component id="46d9c" class="javax.swing.JLabel" binding="SearchLabel">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <labelFor value="56d58"/>
              <text value="搜索："/>
            </properties>
          </component>
          <component id="56d58" class="javax.swing.JTextField" binding="Keyword">
            <constraints>
              <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
            </constraints>
            <properties/>
          </component>
          <component id="99d0c" class="javax.swing.JButton" binding="SearchButton">
            <constraints>
              <grid row="1" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="确定"/>
