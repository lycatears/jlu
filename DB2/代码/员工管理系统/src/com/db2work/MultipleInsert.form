<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.db2work.MultipleInsert">
  <grid id="27dc6" binding="MultipleInsert" layout-manager="GridLayoutManager" row-count="5" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="5" left="5" bottom="5" right="5"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="25eb7" binding="ImportFromFilePanel" layout-manager="GridLayoutManager" row-count="2" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none" title="从文件导入"/>
        <children>
          <component id="48440" class="javax.swing.JLabel" binding="ImportFromFileLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <labelFor value="3f130"/>
              <text value="选择本地Excel表格文件："/>
            </properties>
          </component>
          <component id="3f130" class="javax.swing.JTextField" binding="FilePath">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
            </constraints>
            <properties/>
          </component>
          <component id="40835" class="javax.swing.JButton" binding="BrowseFileButton">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <icon value="folder.png"/>
              <text value="浏览..."/>
            </properties>
          </component>
          <component id="ea2e9" class="javax.swing.JButton" binding="ImportButton">
            <constraints>
              <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <icon value="eyes.png"/>
              <text value="预览"/>
            </properties>
          </component>
        </children>
      </grid>
      <component id="8a4ee" class="javax.swing.JButton" binding="CommitButton">
        <constraints>
          <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <icon value="OK.png"/>
          <text value="提交选中行"/>
        </properties>
      </component>
      <grid id="f09ec" layout-manager="GridLayoutManager" row-count="2" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="e88d0" class="javax.swing.JButton" binding="DeleteRowButton">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <icon value="remove.png"/>
              <text value="移除选中行"/>
            </properties>
          </component>
          <component id="f0be3" class="javax.swing.JButton" binding="NewRowButton">
            <constraints>
              <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <icon value="add.png"/>
              <text value="添加新行..."/>
            </properties>
          </component>
          <component id="1e10" class="javax.swing.JButton" binding="SelectAllButton">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <icon value="allSelect.png"/>
              <text value="全选"/>
            </properties>
          </component>
          <component id="5ddfd" class="javax.swing.JButton" binding="DeSelectAllButton">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <icon value="deselect.png"/>
              <text value="全不选"/>
            </properties>
          </component>
        </children>
      </grid>
      <component id="1bf6a" class="javax.swing.JLabel" binding="PromptLabel">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="您可从文件批量导入信息，或者手动输入。要手动添加信息，请点击右下方的“添加新行”。"/>
        </properties>
      </component>
      <grid id="49c9e" binding="ToImport" layout-manager="GridLayoutManager" row-count="2" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <scrollpane id="23fe9" binding="ToImportPanel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="3" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <horizontalScrollBarPolicy value="32"/>
              <verticalScrollBarPolicy value="22"/>
            </properties>
            <border type="none" title="待导入的行"/>
            <children>
              <component id="a3d53" class="javax.swing.JTable" binding="ImportTable">
                <constraints/>
                <properties>
                  <autoCreateRowSorter value="true"/>
                  <autoResizeMode value="0"/>
                  <font size="14"/>
                </properties>
              </component>
            </children>
          </scrollpane>
          <component id="55d5a" class="javax.swing.JLabel" binding="SearchLabel">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="搜索："/>
            </properties>
          </component>
          <component id="16f7b" class="javax.swing.JTextField" binding="Keyword">
            <constraints>
              <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
            </constraints>
            <properties/>
          </component>
          <component id="6bc65" class="javax.swing.JButton" binding="SearchButton">
            <constraints>
              <grid row="1" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="确定"/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
