<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.db2work.ShowPhoto">
  <grid id="27dc6" binding="ShowPhoto" layout-manager="GridLayoutManager" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none" title=""/>
    <children>
      <grid id="72ae5" binding="EmpnoPanel" layout-manager="GridLayoutManager" row-count="4" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="1" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none" title="查看员工图片"/>
        <children>
          <component id="e0852" class="javax.swing.JTextField" binding="EMPNO">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
            </constraints>
            <properties/>
          </component>
          <component id="eba24" class="javax.swing.JLabel" binding="EnterEmpnoPrompt">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="输入员工工号："/>
            </properties>
          </component>
          <component id="5ea56" class="javax.swing.JLabel" binding="FilePathPrompt">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="输入导出路径："/>
            </properties>
          </component>
          <component id="bd1c9" class="javax.swing.JTextField" binding="FilePath">
            <constraints>
              <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
            </constraints>
            <properties/>
          </component>
          <component id="d0d84" class="javax.swing.JButton" binding="BrowseButton">
            <constraints>
              <grid row="3" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="浏览..."/>
            </properties>
          </component>
          <component id="83709" class="javax.swing.JButton" binding="OKButton">
            <constraints>
              <grid row="3" column="2" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="下载"/>
            </properties>
          </component>
          <component id="428c6" class="javax.swing.JButton" binding="ShowButton">
            <constraints>
              <grid row="1" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="查看"/>
            </properties>
          </component>
        </children>
      </grid>
      <scrollpane id="7867b">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="9a9a9" binding="PreviewPanel" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
            <constraints/>
            <properties/>
            <border type="none" title="预览"/>
            <children>
              <component id="f55a4" class="javax.swing.JLabel" binding="PhotoLabel">
                <constraints/>
                <properties>
                  <text value="选择员工工号后，图片将在此显示。"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </scrollpane>
    </children>
  </grid>
</form>
