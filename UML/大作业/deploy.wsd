@startuml
node "客户端" {
    [浏览器]
    [App]
}

node "应用服务器" {
    [航班查询服务]
    [预定航班服务]
    [支付服务]
    [通知服务]
    [用户管理服务]
}

node "数据库服务器" {
    [航班预定数据库]
    [用户数据数据库]
    [航班信息数据库]
}

node "支付接口" {
    [外部支付接口]
}

node "通知接口" {
    [短信通知接口]
    [推送服务接口]
}

"客户端" --> "应用服务器": HTTPS 请求
"应用服务器" --> "数据库服务器": SQL 语句
"应用服务器" --> "支付接口": API 调用
"应用服务器" --> "通知接口": 通知请求
@enduml
