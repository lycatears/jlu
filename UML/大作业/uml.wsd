@startuml
class 旅客 {
  +提交改签申请
  +确认改签信息
  +接收退款
}

class 系统界面 {
  +显示订单详情
  +接收改签申请
  +显示改签信息
  +提示申请超时
}

class 改签模块 {
  +处理改签申请
  +计算改签手续费及应退金额
  +生成改签记录
  +执行退款操作
}

class 订单管理模块 {
  +查询订单详情
  +更新订单状态
}

class 支付模块 {
  +处理手续费
}

class 错误提示模块 {
  +生成超时提示
}

旅客 --> 系统界面: 交互
系统界面 --> 改签模块: 提交改签申请
改签模块 --> 订单管理模块: 查询订单详情
改签模块 --> 支付模块: 执行退款
改签模块 --> 错误提示模块: 生成超时提示
@enduml

@startuml
class 旅客 {
  +查询航班
  +预订单程航班
  +预订往返票
  +接收航班动态通知
  +选择支付方式
  +查看订单
  +修改订单
  +取消订单
  +申请退票
  +申请改签
  +选择附加服务
}

class 航空公司管理员 {
  +添加航班信息
  +修改航班信息
  +删除航班信息
  +管理座位数量
  +设置舱位和票价
  +查看销售情况
  +配置促销活动
}

class 系统管理员 {
  +管理用户权限
  +审计用户行为
  +监控系统状态
  +数据备份与恢复
}

class 系统界面 {
  +显示航班查询结果
  +显示预订页面
  +显示支付页面
  +显示订单详情
  +显示退票信息
  +显示航班动态通知
  +显示附加服务选项
}

class 航班查询模块 {
  +处理航班查询请求
  +提供多维度筛选
}

class 预订模块 {
  +处理航班预订请求
  +生成订单
}

class 支付模块 {
  +处理支付请求
  +支持多种支付方式
}

class 订单管理模块 {
  +管理订单状态
  +处理退票申请
  +处理改签申请
}

class 通知模块 {
  +发送航班动态通知
}

class 附加服务模块 {
  +处理附加服务选择
  +计算附加服务费用
}

class 航班管理模块 {
  +管理航班信息
  +管理座位和舱位
}

class 销售统计模块 {
  +统计销售情况
  +提供余票信息
}

class 促销管理模块 {
  +配置促销活动
}

class 权限管理模块 {
  +管理用户权限
}

class 审计模块 {
  +审计用户行为
}

class 系统监控模块 {
  +监控系统状态
}

class 数据备份恢复模块 {
  +执行数据备份
  +执行数据恢复
}

旅客 --> 系统界面: 交互
系统界面 --> 航班查询模块: 查询航班
系统界面 --> 预订模块: 预订航班
系统界面 --> 支付模块: 选择支付方式
系统界面 --> 订单管理模块: 管理订单
系统界面 --> 通知模块: 接收通知
系统界面 --> 附加服务模块: 选择附加服务

航空公司管理员 --> 航班管理模块: 管理航班
航空公司管理员 --> 销售统计模块: 查看销售情况
航空公司管理员 --> 促销管理模块: 配置促销活动

系统管理员 --> 权限管理模块: 管理权限
系统管理员 --> 审计模块: 审计行为
系统管理员 --> 系统监控模块: 监控系统
系统管理员 --> 数据备份恢复模块: 备份与恢复
@enduml